{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "baseUrl": ".",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "vite/client"
    ],
    "skipLibCheck": true,
    "jsx": "react-jsx",
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/shared/pages/Checkout",
    "src/shared/pages/Developer",
    "src/shared/pages/GiftCards",
    "src/shared/pages/InvoiceDetails",
    "src/shared/pages/Profile",
    "src/shared/pages/ProfileQR",
    "src/shared/pages/SupportFeedback",
    "src/shared/pages/TelegramBot",
    "src/shared/pages/TelegramLink",
    "src/desktop/pages/Docs",
    "src/desktop/pages/Explorer",
    "src/desktop/pages/Home",
    "src/desktop/pages/Payment",
    "src/desktop/pages/Privacy",
    "src/desktop/pages/Verification",
    "src/desktop/pages/Vision",
    "src/mobile/pages/CreateInvoice",
    "src/mobile/pages/Payment"
  ]
}
